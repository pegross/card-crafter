; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Dead Air"
config/description="M0 skeleton — action-driven survival card sim (concept prototype)."
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

Game="*res://autoload/game.gd"
Audio="*res://autoload/audio.gd"

[audio]

default_bus_layout="res://default_bus_layout.tres"

[display]

window/size/viewport_width=1180
window/size/viewport_height=900
window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]

renderer/rendering_method="gl_compatibility"
environment/defaults/default_clear_color=Color(0.039, 0.055, 0.075, 1)
